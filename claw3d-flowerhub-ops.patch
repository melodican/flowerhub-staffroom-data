+  };
+}
+
+// ── Helpers ────────────────────────────────────────────────────────────────
+
+const REFRESH_INTERVAL_MS = 60_000;
+
+function fmtTime(iso: string | null): string {
+  if (!iso) return "—";
+  const d = new Date(iso);
+  return d.toLocaleTimeString("en-GB", { hour: "2-digit", minute: "2-digit" });
+}
+
+function fmtAgo(iso: string | null): string {
+  if (!iso) return "—";
+  const deltaMs = Date.now() - new Date(iso).getTime();
+  if (deltaMs < 60_000) return "just now";
+  if (deltaMs < 3_600_000) return `${Math.floor(deltaMs / 60_000)}m ago`;
+  return `${Math.floor(deltaMs / 3_600_000)}h ago`;
+}
+
+// ── Sub-components ─────────────────────────────────────────────────────────
+
+function StatusBadge({ status }: { status: DataStatus }) {
+  const styles: Record<DataStatus, string> = {
+    LIVE: "bg-emerald-500/15 text-emerald-300 border-emerald-500/25",
+    STALE: "bg-amber-500/15 text-amber-300 border-amber-500/25",
+    MISSING: "bg-red-500/15 text-red-300 border-red-500/25",
+  };
+  return (
+    <span
+      className={`rounded border px-1.5 py-0.5 font-mono text-[10px] uppercase tracking-[0.16em] ${styles[status]}`}
+    >
+      {status}
+    </span>
+  );
+}
+
+function PanelHeader({
+  title,
+  source,
+}: {
+  title: string;
+  source: SourceMeta;
+}) {
+  return (
+    <div className="flex items-center justify-between border-b border-cyan-500/10 px-4 py-3">
+      <div>
+        <div className="font-mono text-[11px] font-semibold uppercase tracking-[0.22em] text-white/70">
+          {title}
+        </div>
+        <div className="mt-0.5 font-mono text-[10px] text-white/35">
+          updated {fmtAgo(source.updatedAt)} · {fmtTime(source.updatedAt)}
+        </div>
+      </div>
+      <StatusBadge status={source.status} />
+    </div>
+  );
+}
+
+function AgentsPanel({
+  agents,
+  source,
+  agentRoutes,
+}: {
+  agents: ActiveAgent[];
+  source: SourceMeta;
+  agentRoutes: AgentRoute[];
+}) {
+  const roleMap = Object.fromEntries(agentRoutes.map((r) => [r.name.toLowerCase(), r.role]));
+
+  return (
+    <div className="flex h-full flex-col">
+      <PanelHeader title="Active Agents" source={source} />
+      <div className="min-h-0 flex-1 overflow-y-auto px-2 py-2">
+        {source.status === "MISSING" ? (
+          <Empty text="active_tasks.json not found" />
+        ) : agents.length === 0 ? (
+          <Empty text="No active agents in feed" />
+        ) : (
+          agents.map((a) => {
+            const isLive = a.source === "runtime";
+            const hbAgo = a.last_heartbeat ? fmtAgo(a.last_heartbeat) : null;
+            return (
+              <div
+                key={a.agent}
+                className="mb-2 rounded border border-white/8 bg-white/[0.03] px-3 py-3"
+              >
+                <div className="flex items-center gap-2">
+                  <span
+                    className={`h-2 w-2 shrink-0 rounded-full ${
+                      a.status === "working"
+                        ? "bg-emerald-400"
+                        : a.status === "blocked"
+                          ? "bg-red-400"
+                          : "bg-amber-400/70"
+                    }`}
+                  />
+                  <span className="flex-1 truncate font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-white/85">
+                    {a.agent}
+                  </span>
+                  {isLive && (
+                    <span className="rounded bg-emerald-500/15 px-1.5 py-0.5 font-mono text-[10px] uppercase tracking-[0.1em] text-emerald-300">
+                      live
+                    </span>
+                  )}
+                </div>
+                {a.current_task ? (
+                  <div className="mt-1.5 line-clamp-2 font-mono text-[11px] leading-5 text-white/60">
+                    {a.current_task}
+                  </div>
+                ) : null}
+                <div className="mt-1.5 flex items-center gap-3 font-mono text-[10px] text-white/35">
+                  {roleMap[a.agent.toLowerCase()] ? (
+                    <span>{roleMap[a.agent.toLowerCase()]}</span>
+                  ) : null}
+                  {hbAgo ? <span>♡ {hbAgo}</span> : null}
+                  {a.confidence ? (
+                    <span className="capitalize">{a.confidence} confidence</span>
+                  ) : null}
+                </div>
+              </div>
+            );
+          })
+        )}
+      </div>
+    </div>
+  );
+}
+
+function SprintPanel({
+  cards,
+  source,
+}: {
+  cards: SprintCard[];
+  source: SourceMeta;
+}) {
+  const active = cards.filter((c) => c.status === "ACTIVE");
+  const queued = cards.filter((c) => c.status !== "ACTIVE");
+
+  return (
+    <div className="flex h-full flex-col">
+      <PanelHeader title="Sprint Board" source={source} />
+      <div className="min-h-0 flex-1 overflow-y-auto px-2 py-2">
+        {source.status === "MISSING" ? (
+          <Empty text="OFFICE-BOARD.md not found" />
+        ) : cards.length === 0 ? (
+          <Empty text="No sprint cards parsed" />
+        ) : (
+          <>
+            {active.length > 0 && (
+              <div className="mb-1 px-2 pb-1 font-mono text-[10px] uppercase tracking-[0.18em] text-cyan-300/60">
+                Active ({active.length})
+              </div>
+            )}
+            {active.map((c) => (
+              <SprintCard key={c.id} card={c} />
+            ))}
+            {queued.length > 0 && (
+              <div className="mb-1 mt-3 px-2 pb-1 font-mono text-[10px] uppercase tracking-[0.18em] text-white/35">
+                Queued ({queued.length})
+              </div>
+            )}
+            {queued.map((c) => (
+              <SprintCard key={c.id} card={c} />
+            ))}
+          </>
+        )}
+      </div>
+    </div>
+  );
+}
+
+function SprintCard({ card }: { card: SprintCard }) {
+  const isActive = card.status === "ACTIVE";
+  return (
+    <div
+      className={`mb-2 rounded border px-3 py-2.5 ${
+        isActive
+          ? "border-cyan-500/20 bg-cyan-500/[0.04]"
+          : "border-white/8 bg-white/[0.02]"
+      }`}
+    >
+      <div className="flex items-start gap-2">
+        <span
+          className={`mt-0.5 shrink-0 font-mono text-[10px] font-semibold uppercase tracking-[0.12em] ${
+            isActive ? "text-cyan-400" : "text-white/35"
+          }`}
+        >
+          {card.id}
+        </span>
+        <span className="font-mono text-[11px] leading-5 text-white/80">
+          {card.task}
+        </span>
+      </div>
+      <div className="mt-1.5 flex flex-wrap gap-x-3 gap-y-0.5 font-mono text-[10px] text-white/35">
+        {card.owner ? <span>👤 {card.owner}</span> : null}
+        {card.deadline ? <span>⏱ {card.deadline}</span> : null}
+      </div>
+      {card.kpi ? (
+        <div className="mt-1 font-mono text-[10px] leading-4 text-white/30">
+          KPI: {card.kpi}
+        </div>
+      ) : null}
+    </div>
+  );
+}
+
+function TaskQueuePanel({
+  cards,
+  source,
+}: {
+  cards: TaskCard[];
+  source: SourceMeta;
+}) {
+  return (
+    <div className="flex h-full flex-col">
+      <PanelHeader title="Task Queue (WIP=1)" source={source} />
+      <div className="min-h-0 flex-1 overflow-y-auto px-2 py-2">
+        {source.status === "MISSING" ? (
+          <Empty text="TASK-BOARD.md not found" />
+        ) : cards.length === 0 ? (
+          <Empty text="No task cards parsed" />
+        ) : (
+          cards.map((c, i) => {
+            const isActive = c.status === "ACTIVE";
+            return (
+              <div
+                key={c.id}
+                className={`mb-2 rounded border px-3 py-3 ${
+                  isActive
+                    ? "border-emerald-500/25 bg-emerald-500/[0.04]"
