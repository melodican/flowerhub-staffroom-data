+                    {c.kpi ? (
+                      <div className="mt-1 font-mono text-[10px] text-white/30">
+                        KPI: {c.kpi}
+                      </div>
+                    ) : null}
+                  </div>
+                </div>
+              </div>
+            );
+          })
+        )}
+      </div>
+    </div>
+  );
+}
+
+function InboxPanel({
+  items,
+  source,
+}: {
+  items: InboxItem[];
+  source: SourceMeta;
+}) {
+  const needsHuman = items.filter((i) => i.needs_human);
+  const rest = items.filter((i) => !i.needs_human).slice(0, 8);
+
+  return (
+    <div className="flex h-full flex-col">
+      <PanelHeader title="Inbox Queue" source={source} />
+      <div className="min-h-0 flex-1 overflow-y-auto px-2 py-2">
+        {source.status === "MISSING" ? (
+          <Empty text="inbox_queue.json not found" />
+        ) : items.length === 0 ? (
+          <Empty text="Inbox queue is empty" />
+        ) : (
+          <>
+            {needsHuman.length > 0 && (
+              <>
+                <div className="mb-1 px-2 pb-1 font-mono text-[10px] uppercase tracking-[0.18em] text-amber-300/70">
+                  Needs Human ({needsHuman.length})
+                </div>
+                {needsHuman.map((item) => (
+                  <InboxRow key={item.id} item={item} highlight />
+                ))}
+                {rest.length > 0 && (
+                  <div className="mb-1 mt-3 px-2 pb-1 font-mono text-[10px] uppercase tracking-[0.18em] text-white/35">
+                    Recent
+                  </div>
+                )}
