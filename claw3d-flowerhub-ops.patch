+
+// ── Types ──────────────────────────────────────────────────────────────────
+
+type DataStatus = "LIVE" | "STALE" | "MISSING";
+
+interface SourceMeta {
+  status: DataStatus;
+  updatedAt: string | null;
+}
+
+interface OpsData {
+  activeAgents: ActiveAgent[];
+  inboxItems: InboxItem[];
+  officeBoard: OfficeBoardData | null;
+  taskCards: TaskCard[];
