@@ -0,0 +1,261 @@
+import { NextResponse } from "next/server";
+import fs from "node:fs";
+import path from "node:path";
+
+export const dynamic = "force-dynamic";
+
+const DATA_DIR =
+  process.env.FLOWERHUB_DATA_DIR ??
+  "/Users/glenkirkham/flowerhub-staffroom-data/data";
+
+// Stale thresholds per source
+const STALE_MS = {
+  activeTasks: 10 * 60 * 1000, // 10 min — agents heartbeat frequently
+  inboxQueue: 60 * 60 * 1000, // 60 min — inbox syncs hourly
+  officeBoard: 24 * 60 * 60 * 1000, // 24 h — edited manually
+  taskBoard: 24 * 60 * 60 * 1000, // 24 h — edited manually
+} as const;
+
+type DataStatus = "LIVE" | "STALE" | "MISSING";
+
+// ── File helpers ───────────────────────────────────────────────────────────
+
+function readLocal(filename: string): { content: string | null; mtime: Date | null } {
+  try {
+    const filepath = path.join(DATA_DIR, filename);
+    const stat = fs.statSync(filepath);
+    const content = fs.readFileSync(filepath, "utf-8");
+    return { content, mtime: stat.mtime };
+  } catch {
+    return { content: null, mtime: null };
+  }
+}
+
+function statusFor(updatedAt: Date | null, thresholdMs: number): DataStatus {
+  if (!updatedAt) return "MISSING";
+  return Date.now() - updatedAt.getTime() > thresholdMs ? "STALE" : "LIVE";
+}
+
+// ── TASK-BOARD.md parser ───────────────────────────────────────────────────
+
+export interface TaskCard {
+  id: string;
+  title: string;
+  owner: string;
+  deadline: string;
+  kpi: string;
+  status: "ACTIVE" | "QUEUED" | "BLOCKED" | string;
+}
+
+function parseTaskBoard(md: string): TaskCard[] {
+  const cards: TaskCard[] = [];
+  // Match ## Card N (STATUS) sections
+  const sections = md.split(/^## /m).slice(1);
+  for (const section of sections) {
+    const headerMatch = section.match(/^(Card \d+)\s*\(([^)]+)\)/i);
+    if (!headerMatch) continue;
+    const id = headerMatch[1];
+    const statusFromHeader = headerMatch[2].trim().toUpperCase();
+
+    const field = (key: string) => {
+      const m = section.match(new RegExp(`\\*\\*${key}:\\*\\*\\s*(.+)`, "i"));
+      return m ? m[1].trim() : "";
+    };
+
+    cards.push({
+      id,
+      title: field("Title"),
+      owner: field("Owner"),
+      deadline: field("Deadline"),
+      kpi: field("KPI"),
+      status: field("Status").toUpperCase() || statusFromHeader,
+    });
+  }
+  return cards;
+}
+
+// ── OFFICE-BOARD.md parser ─────────────────────────────────────────────────
+
+export interface SprintCard {
+  id: string;
+  task: string;
+  owner: string;
+  deadline: string;
+  kpi: string;
+  status: "ACTIVE" | "QUEUED" | "BLOCKED" | string;
+}
+
+export interface AgentRoute {
+  name: string;
+  role: string;
+}
+
+export interface OfficeBoardData {
+  objective: string;
+  priorities: string[];
+  sprintCards: SprintCard[];
+  agentRoutes: AgentRoute[];
+  lastUpdated: string;
+}
+
+function parseOfficeBoard(md: string): OfficeBoardData {
+  const objective =
+    md.match(/## Company Objective\s*\n([^\n#]+)/)?.[1]?.trim() ?? "";
+
+  const lastUpdated =
+    md.match(/Last updated:\s*([^\n]+)/)?.[1]?.trim() ?? "";
+
+  // Priority list
+  const priorityBlock = md.match(/## Priority Order[\s\S]*?\n((?:\d+\..+\n?)+)/);
+  const priorities: string[] = [];
+  if (priorityBlock) {
+    for (const line of priorityBlock[1].split("\n")) {
+      const m = line.match(/^\d+\.\s*(.+)/);
+      if (m) priorities.push(m[1].trim());
+    }
+  }
+
+  // Sprint cards (### Card AN (...))
+  const sprintCards: SprintCard[] = [];
+  const sprintSection = md.match(/## Active Sprint[\s\S]*/)?.[0] ?? "";
+  const cardSections = sprintSection.split(/^### /m).slice(1);
+  for (const section of cardSections) {
+    const headerMatch = section.match(/^(Card [A-Z0-9]+)\s*\(([^)]+)\)/i);
+    if (!headerMatch) continue;
+    const id = headerMatch[1];
+    const statusFromHeader = headerMatch[2].trim().toUpperCase();
+
+    const field = (key: string) => {
+      const m = section.match(new RegExp(`^- ${key}:\\s*(.+)`, "im"));
+      return m ? m[1].trim() : "";
+    };
+
+    sprintCards.push({
+      id,
+      task: field("Task"),
+      owner: field("Owner"),
+      deadline: field("Deadline"),
+      kpi: field("KPI"),
+      status: field("Status").toUpperCase() || statusFromHeader,
+    });
+  }
+
+  // Agent route map
+  const agentRoutes: AgentRoute[] = [];
+  const routeSection = md.match(/## Agent Route Map([\s\S]*?)(?=\n##|$)/)?.[1] ?? "";
+  for (const line of routeSection.split("\n")) {
+    const m = line.match(/^- ([^:]+):\s*(.+)/);
+    if (m) agentRoutes.push({ name: m[1].trim(), role: m[2].trim() });
+  }
+
+  return { objective, lastUpdated, priorities, sprintCards, agentRoutes };
+}
+
+// ── Active tasks shape ─────────────────────────────────────────────────────
+
+export interface ActiveAgent {
+  agent: string;
+  status: string;
+  current_task: string;
+  started_at?: string;
+  last_heartbeat?: string;
+  source?: string;
+  confidence?: string;
+}
+
+// ── Inbox shape ────────────────────────────────────────────────────────────
+
+export interface InboxItem {
+  id: string;
+  from: string;
+  subject: string;
+  category: string;
+  assigned_to: string;
+  status: string;
+  needs_human?: boolean;
+  received: string;
+  created_at_utc?: string;
+}
+
+// ── In-memory cache ────────────────────────────────────────────────────────
+
+let _cache: { data: unknown; at: number } | null = null;
+const CACHE_TTL_MS = 30_000;
+
+// ── Route handler ──────────────────────────────────────────────────────────
+
+export async function GET() {
+  if (_cache && Date.now() - _cache.at < CACHE_TTL_MS) {
+    return NextResponse.json(_cache.data);
+  }
+
+  const now = new Date().toISOString();
+
+  // active_tasks.json
+  const { content: atRaw, mtime: atMtime } = readLocal("active_tasks.json");
+  let activeAgents: ActiveAgent[] = [];
+  let atUpdatedAt: Date | null = null;
+  if (atRaw) {
+    try {
+      const parsed: { updated_at?: string; agents?: ActiveAgent[] } = JSON.parse(atRaw);
+      activeAgents = parsed.agents ?? [];
+      atUpdatedAt = parsed.updated_at ? new Date(parsed.updated_at) : atMtime;
+    } catch {
+      atUpdatedAt = atMtime;
+    }
+  }
+
+  // inbox_queue.json
+  const { content: iqRaw, mtime: iqMtime } = readLocal("inbox_queue.json");
+  let inboxItems: InboxItem[] = [];
+  let iqUpdatedAt: Date | null = null;
+  if (iqRaw) {
+    try {
+      const parsed: { updated_at_utc?: string; items?: InboxItem[] } = JSON.parse(iqRaw);
+      inboxItems = parsed.items ?? [];
+      iqUpdatedAt = parsed.updated_at_utc ? new Date(parsed.updated_at_utc) : iqMtime;
+    } catch {
+      iqUpdatedAt = iqMtime;
+    }
+  }
+
+  // OFFICE-BOARD.md
+  const { content: obRaw, mtime: obMtime } = readLocal("OFFICE-BOARD.md");
+  const officeBoard: OfficeBoardData | null = obRaw ? parseOfficeBoard(obRaw) : null;
+
+  // TASK-BOARD.md
+  const { content: tbRaw, mtime: tbMtime } = readLocal("TASK-BOARD.md");
+  const taskCards: TaskCard[] = tbRaw ? parseTaskBoard(tbRaw) : [];
+
+  const data = {
+    activeAgents,
+    inboxItems: inboxItems.slice(0, 20), // cap for UI
+    officeBoard,
+    taskCards,
+    meta: {
+      generatedAt: now,
+      dataDir: DATA_DIR,
+      sources: {
+        activeTasks: {
+          status: statusFor(atUpdatedAt, STALE_MS.activeTasks),
+          updatedAt: atUpdatedAt?.toISOString() ?? null,
+        },
+        inboxQueue: {
+          status: statusFor(iqUpdatedAt, STALE_MS.inboxQueue),
+          updatedAt: iqUpdatedAt?.toISOString() ?? null,
+        },
+        officeBoard: {
+          status: statusFor(obMtime, STALE_MS.officeBoard),
+          updatedAt: obMtime?.toISOString() ?? null,
+        },
+        taskBoard: {
+          status: statusFor(tbMtime, STALE_MS.taskBoard),
+          updatedAt: tbMtime?.toISOString() ?? null,
+        },
+      },
+    },
+  };
+
+  _cache = { data, at: Date.now() };
+  return NextResponse.json(data);
+}
