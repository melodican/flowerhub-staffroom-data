+        <span className="truncate">{item.from}</span>
+        {item.assigned_to ? <span>→ {item.assigned_to}</span> : null}
+        {item.status ? (
+          <span className="capitalize">{item.status.replace(/_/g, " ")}</span>
+        ) : null}
