+import type { Metadata } from "next";
+import { FlowerhubOpsView } from "@/features/flowerhub-ops/FlowerhubOpsView";
+
+export const dynamic = "force-dynamic";
+
+export const metadata: Metadata = {
+  title: "FlowerHub Ops · Claw3D",
+  description: "FlowerHub 3D Operations Office — real-time agent and task monitoring.",
+  robots: "noindex, nofollow",
+};
+
+async function fetchOpsData() {
+  try {
+    // Server-side: call own API directly rather than going through network
+    const { GET } = await import("@/app/api/flowerhub-ops/route");
+    const res = await GET();
+    return res.json() as Promise<Parameters<typeof FlowerhubOpsView>[0]["initial"]>;
+  } catch {
+    // Fallback empty state — client will fetch on mount
+    return {
+      activeAgents: [],
+      inboxItems: [],
+      officeBoard: null,
+      taskCards: [],
+      meta: {
+        generatedAt: new Date().toISOString(),
+        dataDir: "",
+        sources: {
+          activeTasks: { status: "MISSING" as const, updatedAt: null },
+          inboxQueue: { status: "MISSING" as const, updatedAt: null },
+          officeBoard: { status: "MISSING" as const, updatedAt: null },
+          taskBoard: { status: "MISSING" as const, updatedAt: null },
+        },
+      },
+    };
+  }
+}
+
+export default async function FlowerhubPage() {
+  const initial = await fetchOpsData();
+  return <FlowerhubOpsView initial={initial} />;
+}
