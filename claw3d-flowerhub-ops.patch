+            )}
+            {rest.map((item) => (
+              <InboxRow key={item.id} item={item} highlight={false} />
+            ))}
+          </>
+        )}
+      </div>
+    </div>
+  );
+}
+
+function InboxRow({
+  item,
+  highlight,
+}: {
+  item: InboxItem;
+  highlight: boolean;
+}) {
+  return (
+    <div
+      className={`mb-1.5 rounded border px-3 py-2 ${
+        highlight
