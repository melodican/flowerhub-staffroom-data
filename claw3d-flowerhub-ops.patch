+}
+
+function Empty({ text }: { text: string }) {
+  return (
+    <div className="px-2 py-6 font-mono text-[11px] text-white/30">{text}</div>
+  );
+}
+
+// ── Main view ──────────────────────────────────────────────────────────────
+
+export function FlowerhubOpsView({ initial }: { initial: OpsData }) {
+  const [data, setData] = useState<OpsData>(initial);
+  const [loading, setLoading] = useState(false);
+  const [lastFetch, setLastFetch] = useState<Date>(new Date());
+  const [countdown, setCountdown] = useState(REFRESH_INTERVAL_MS / 1000);
+  const timerRef = useRef<ReturnType<typeof setInterval> | null>(null);
+
+  const refresh = useCallback(async () => {
+    setLoading(true);
+    try {
+      const res = await fetch("/api/flowerhub-ops", { cache: "no-store" });
+      if (res.ok) {
+        const next = (await res.json()) as OpsData;
+        setData(next);
+        setLastFetch(new Date());
+      }
+    } catch {
+      // keep stale data
+    } finally {
+      setLoading(false);
+      setCountdown(REFRESH_INTERVAL_MS / 1000);
+    }
+  }, []);
+
+  // Auto-refresh every 60s
+  useEffect(() => {
+    timerRef.current = setInterval(() => {
+      void refresh();
+    }, REFRESH_INTERVAL_MS);
+    return () => {
+      if (timerRef.current) clearInterval(timerRef.current);
+    };
+  }, [refresh]);
+
+  // Countdown ticker
+  useEffect(() => {
+    const tick = setInterval(() => {
+      setCountdown((prev) => (prev <= 1 ? REFRESH_INTERVAL_MS / 1000 : prev - 1));
+    }, 1000);
+    return () => clearInterval(tick);
+  }, []);
+
+  const { sources } = data.meta;
+  const agentRoutes = data.officeBoard?.agentRoutes ?? [];
+
+  const overallStatus = Object.values(sources).some((s) => s.status === "MISSING")
+    ? "MISSING"
+    : Object.values(sources).some((s) => s.status === "STALE")
+      ? "STALE"
+      : "LIVE";
+
+  return (
+    <div className="flex h-screen flex-col bg-[#06090d] text-white">
+      {/* Header */}
+      <header className="flex shrink-0 items-center justify-between border-b border-cyan-500/15 bg-black/60 px-6 py-3 backdrop-blur">
+        <div className="flex items-center gap-4">
+          <div>
+            <div className="font-mono text-[13px] font-semibold uppercase tracking-[0.22em] text-cyan-300">
+              FlowerHub Ops
+            </div>
+            <div className="font-mono text-[10px] text-white/40">
+              3D Mission Control · {data.officeBoard?.objective ?? "Loading…"}
+            </div>
+          </div>
+          <StatusBadge status={overallStatus} />
+        </div>
+
+        <div className="flex items-center gap-4">
+          <div className="font-mono text-[10px] text-white/35">
+            synced {fmtAgo(lastFetch.toISOString())} · refresh in {countdown}s
+          </div>
+          <button
+            type="button"
+            onClick={() => void refresh()}
+            disabled={loading}
+            className="rounded border border-cyan-500/25 bg-cyan-500/10 px-3 py-1.5 font-mono text-[11px] uppercase tracking-[0.14em] text-cyan-300 transition-colors hover:border-cyan-400/50 hover:bg-cyan-500/15 disabled:opacity-40"
+          >
+            {loading ? "Syncing…" : "↺ Refresh"}
+          </button>
+        </div>
+      </header>
+
+      {/* Priority strip */}
+      {data.officeBoard?.priorities && data.officeBoard.priorities.length > 0 && (
+        <div className="shrink-0 border-b border-white/5 bg-black/30 px-6 py-2">
+          <div className="flex items-center gap-3 overflow-x-auto">
+            <span className="shrink-0 font-mono text-[10px] uppercase tracking-[0.18em] text-white/30">
+              Priorities:
+            </span>
+            {data.officeBoard.priorities.map((p, i) => (
+              <span
+                key={i}
+                className="shrink-0 rounded bg-white/5 px-2 py-0.5 font-mono text-[10px] text-white/50"
+              >
+                {i + 1}. {p}
+              </span>
+            ))}
+          </div>
+        </div>
+      )}
+
+      {/* 4-panel grid */}
+      <div className="grid min-h-0 flex-1 grid-cols-2 grid-rows-2 gap-px bg-white/5">
+        {/* Top-left: Active Agents */}
+        <div className="overflow-hidden bg-[#06090d]">
+          <AgentsPanel
+            agents={data.activeAgents}
+            source={sources.activeTasks}
+            agentRoutes={agentRoutes}
+          />
+        </div>
+
+        {/* Top-right: Sprint Board */}
+        <div className="overflow-hidden bg-[#06090d]">
+          <SprintPanel cards={data.officeBoard?.sprintCards ?? []} source={sources.officeBoard} />
+        </div>
+
+        {/* Bottom-left: Task Queue */}
+        <div className="overflow-hidden bg-[#06090d]">
+          <TaskQueuePanel cards={data.taskCards} source={sources.taskBoard} />
+        </div>
+
+        {/* Bottom-right: Inbox */}
+        <div className="overflow-hidden bg-[#06090d]">
+          <InboxPanel items={data.inboxItems} source={sources.inboxQueue} />
+        </div>
+      </div>
+    </div>
+  );
+}
